{
    "configurations": [
        {
            "name": "AVR ATmega8",
            "includePath": [
                "${workspaceFolder}/**",
                "/usr/lib/avr/include"
            ],
            "defines": [
                "__AVR_ATmega8__",
                "F_CPU=16000000UL"
            ],
            "compilerPath": "/usr/bin/avr-gcc",
            "compilerArgs": [
                "-mmcu=atmega8"
            ],
            "cStandard": "gnu99",
            "intelliSenseMode": "gcc-x64"
        }
    ],
    "version": 4
}
